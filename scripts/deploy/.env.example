# 必填：远端服务器地址 (IP 或域名)
TENCENT_SERVER_HOST=

# 可选：以下都有默认值
TENCENT_SERVER_USER=root
TENCENT_SERVER_PORT=22
TENCENT_SSH_KEY=~/.ssh/id_rsa
REMOTE_DIR=/opt/website/opc-website/python4office.cn
LOCAL_PUBLIC_DIR=./hexo/hexo/public
HEXO_DIR=./hexo/hexo

# 可选开关
# SKIP_BUILD=true   跳过本地构建，直接同步已有 public/
# DRY_RUN=true      只打印要执行的命令，不实际同步
