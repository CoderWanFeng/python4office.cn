{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "node --max-old-space-size=16384 node_modules/.bin/hexo generate",
    "build-fast": "node --max-old-space-size=16384 --expose-gc node_modules/.bin/hexo generate",
    "build-optimized": "bash build-optimized.sh",
    "build-incremental": "node --max-old-space-size=16384 node_modules/.bin/hexo generate --force",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "server": "hexo server"
  },
  "hexo": {
    "version": "7.3.0"
  },
  "dependencies": {
    "bulma-stylus": "^0.8.0",
    "deepmerge": "^4.3.1",
    "hexo": "^7.3.0",
    "hexo-asset-image": "^1.0.0",
    "hexo-component-inferno": "^3.1.2",
    "hexo-deployer-git": "^2.1.0",
    "hexo-generator-archive": "^1.0.0",
    "hexo-generator-category": "^1.0.0",
    "hexo-generator-index": "^2.0.0",
    "hexo-generator-json-content": "^4.2.3",
    "hexo-log": "^4.1.0",
    "hexo-pagination": "^3.0.0",
    "hexo-renderer-ejs": "^1.0.0",
    "hexo-renderer-inferno": "^1.0.2",
    "hexo-renderer-jade": "^0.5.0",
    "hexo-renderer-marked": "^7.0.1",
    "hexo-renderer-pug": "^1.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^2.0.0",
    "hexo-theme-butterfly": "^5.5.4",
    "hexo-theme-icarus": "^4.4.0",
    "hexo-theme-landscape": "^0.0.3",
    "hexo-util": "^3.3.0",
    "hexo-wordcount": "^6.0.1",
    "inferno": "^8.2.3",
    "inferno-create-element": "^8.2.3",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "hexo-clean-css": "^1.0.0",
    "hexo-generator-baidu-sitemap": "^0.1.9",
    "hexo-generator-sitemap": "^2.2.0",
    "hexo-uglify": "^1.0.0"
  }
}