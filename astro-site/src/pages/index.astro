---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>程序员晚枫 - Python自动化办公与AI编程</title>
  </head>
  <body>
    <h1>程序员晚枫 - Python自动化办公与AI编程</h1>
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`/${post.slug}/`}>{post.data.title}</a>
          <br />
          <small>{post.data.date.toLocaleDateString('zh-CN')}</small>
        </li>
      ))}
    </ul>
  </body>
</html>
